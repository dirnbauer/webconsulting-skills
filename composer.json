{
    "name": "webconsulting/webconsulting-skills",
    "description": "Curated Agent Skills for AI-augmented software development (Cursor, Claude Code, Gemini CLI, Codex, Windsurf)",
    "type": "composer-plugin",
    "license": ["MIT", "CC-BY-SA-4.0"],
    "keywords": [
        "ai",
        "agent",
        "skills",
        "claude",
        "cursor",
        "typo3",
        "llm"
    ],
    "authors": [
        {
            "name": "webconsulting.at",
            "homepage": "https://webconsulting.at",
            "role": "Adaptation and additional skills"
        }
    ],
    "require": {
        "php": ">=8.2",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "WebConsulting\\AgentSkills\\": "src/"
        }
    },
    "scripts": {
        "skills:install": "bash install.sh",
        "skills:update": "bash update.sh",
        "skills:sync": "bash update.sh --sync-only",
        "skills:list": "ls -la skills/ | grep ^d | awk '{print $NF}' | tail -n +2"
    },
    "scripts-descriptions": {
        "skills:install": "Install skills to the supported core AI client directories",
        "skills:update": "Sync external skills, regenerate manifests, and reinstall",
        "skills:sync": "Sync external skills and generated files without reinstalling",
        "skills:list": "List all available skills"
    },
    "extra": {
        "class": "WebConsulting\\AgentSkills\\SkillInstallerPlugin"
    },
    "config": {
        "allow-plugins": {
            "webconsulting/webconsulting-skills": true
        }
    }
}
